UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    
    if input.KeyCode == Enum.KeyCode.RightAlt then
        Config.AimAssist = not Config.AimAssist
    elseif input.KeyCode == Enum.KeyCode.V then
        Config.EspEnabled = not Config.EspEnabled
        Config.NameTags = Config.EspEnabled
        Config.Tracers = Config.EspEnabled
    elseif input.KeyCode == Enum.KeyCode.B then
        Config.Bhop = not Config.Bhop
        Config.AutoStrafe = Config.Bhop
    elseif input.KeyCode == Enum.KeyCode.G then
        Config.ShowSpeedGraph = not Config.ShowSpeedGraph
    end
end)
local cache = {}
local function createDrawings(name)
    if cache[name] then return end
    
    local tracer = Drawing.new("Line")
    tracer.Visible = false
    tracer.Color = Config.TracerColor
    tracer.Thickness = 1.0
    
    local label = Drawing.new("Text")
    label.Visible = false
    label.Color = Config.TagColor
    label.Size = 13
    label.Center = true
    label.Outline = true
    
    cache[name] = {
        Tracer = tracer,
        Label = label
    }
end
local function removeDrawings(name)
    local draw = cache[name]
    if draw then
        pcall(function() draw.Tracer:Remove() end)
        pcall(function() draw.Label:Remove() end)
        cache[name] = nil
    end
end
Players.PlayerRemoving:Connect(removeDrawings)
local function getEnemyCharacters()
    local enemies = {}
    local localTeam = LocalPlayer.Team and LocalPlayer.Team.Name or ""
    local localName = LocalPlayer.Name
    
    local folders = {}
    if FrogService and FrogService:FindFirstChild("Characters") then
        for _, f in ipairs(FrogService.Characters:GetChildren()) do
            table.insert(folders, f)
        end
    end
    
    local wsChars = Workspace:FindFirstChild("Characters")
    if wsChars then
        for _, f in ipairs(wsChars:GetChildren()) do
            table.insert(folders, f)
        end
    end
    
    for _, folder in ipairs(folders) do
        if folder:IsA("Folder") and folder.Name ~= "Hostages" and folder.Name ~= localTeam then
            for _, char in ipairs(folder:GetChildren()) do
                if char:IsA("Model") and char.Name ~= localName and char:FindFirstChild("HumanoidRootPart") then
                    local hum = char:FindFirstChildOfClass("Humanoid") or char:FindFirstChildWhichIsA("Humanoid")
                    if hum and hum.Health > 0 then
                        table.insert(enemies, char)
                    end
                end
            end
        end
    end
    return enemies
end
local function getLocalCharacter()
    local localName = LocalPlayer.Name
    if FrogService and FrogService:FindFirstChild("Characters") then
        for _, folder in ipairs(FrogService.Characters:GetChildren()) do
            if folder:IsA("Folder") and folder.Name ~= "Hostages" then
                local myChar = folder:FindFirstChild(localName)
                if myChar then return myChar end
            end
        end
    end
    local wsChars = Workspace:FindFirstChild("Characters")
    if wsChars then
        for _, folder in ipairs(wsChars:GetChildren()) do
            if folder:IsA("Folder") and folder.Name ~= "Hostages" then
                local myChar = folder:FindFirstChild(localName)
                if myChar then return myChar end
            end
        end
    end
    return nil
end
