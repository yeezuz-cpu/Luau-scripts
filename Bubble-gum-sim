    Library.Unloaded = true
end)
local function getActiveWorldSellPart()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    
    local closestPart = nil
    local shortestDist = math.huge
    
    local worldsFolder = Workspace:FindFirstChild("Worlds")
    if worldsFolder then
        for _, world in ipairs(worldsFolder:GetChildren()) do
            local sellModel = world:FindFirstChild("Sell")
            if sellModel then
                local rootPart = sellModel:FindFirstChild("Root")
                if rootPart and rootPart:IsA("BasePart") then
                    local dist = (hrp.Position - rootPart.Position).Magnitude
                    if dist < shortestDist then
                        shortestDist = dist
                        closestPart = rootPart
                    end
                end
            end
        end
    end
    return closestPart
end
task.spawn(function()
    while true do
        if Library.Unloaded then break end
        
        if Config.AutoBubble then
            pcall(function()
                Remote:FireServer("BlowBubble")
            end)
        end
        
        task.wait(Config.BubbleDelay)
    end
end)
task.spawn(function()
    while true do
        if Library.Unloaded then break end
        
        if Config.AutoSell then
            local data = nil
            pcall(function()
                data = LocalData:Get()
            end)
            
            if data and data.Bubble then
                local currentAmount = tonumber(data.Bubble.Amount) or 0
                local maxStorage = 0
                pcall(function()
                    maxStorage = StatsUtil:GetBubbleStorage(data)
                end)
                
                if currentAmount >= maxStorage and maxStorage > 0 then
                    local sellPart = getActiveWorldSellPart()
                    local char = LocalPlayer.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    
                    if sellPart and hrp then
                        local previousCFrame = hrp.CFrame
                        
                        
                        hrp.CFrame = sellPart.CFrame + Vector3.new(0, 3, 0)
                        task.wait()
                        pcall(function()
                            Remote:FireServer("SellBubble")
                        end)
                        task.wait()
                        hrp.CFrame = previousCFrame
                    end
                end
            end
        end
        
        task.wait(0.3)
    end
end)
