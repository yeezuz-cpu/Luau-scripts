local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Camera = Workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local cache = {}

local function createDrawings(player)
    if cache[player] then return end
    
    local tracer = Drawing.new("Line")
    tracer.Visible = false
    tracer.Color = Config.TracerColor
    tracer.Thickness = 1.0
    
    local label = Drawing.new("Text")
    label.Visible = false
    label.Color = Config.TagColor
    label.Size = 13
    label.Center = true
    label.Outline = true
    
    cache[player] = {
        Tracer = tracer,
        Label = label
    }
end

local function removeDrawings(player)
    local draw = cache[player]
    if draw then
        pcall(function() draw.Tracer:Remove() end)
        pcall(function() draw.Label:Remove() end)
        cache[player] = nil
    end
end

Players.PlayerRemoving:Connect(removeDrawings)

local function isTeammate(player)
    if player.Team == nil or LocalPlayer.Team == nil then
        return false
    end
    return player.Team == LocalPlayer.Team
end

local function validPlayer(player)
    return player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0
end

task.spawn(function()
    while true do
        if Library.Unloaded then break end
        
        pcall(function()
            local weaponsFolder = ReplicatedStorage:FindFirstChild("Weapons")
            if weaponsFolder then
                for _, weapon in ipairs(weaponsFolder:GetChildren()) do
                    if weapon:IsA("Folder") then
                        if Config.NoSpread then
                            local spreadFolder = weapon:FindFirstChild("Spread")
                            if spreadFolder then
                                for _, val in ipairs(spreadFolder:GetChildren()) do
                                    if val:IsA("NumberValue") then
                                        val.Value = 0.0001
                                    end
                                end
                            end
                        end
                        if Config.FullAuto then
                            local autoVal = weapon:FindFirstChild("Auto")
                            if autoVal and autoVal:IsA("BoolValue") then
                                autoVal.Value = true
                            end
                        end
                        if Config.FireRateMod then
                            local frVal = weapon:FindFirstChild("FireRate")
                            if frVal and frVal:IsA("NumberValue") then
                                frVal.Value = Config.FireRateValue
                            end
                        end
                        if Config.AmmoMod then
                            local ammoVal = weapon:FindFirstChild("Ammo")
                            local sammoVal = weapon:FindFirstChild("StoredAmmo")
                            if ammoVal and ammoVal:IsA("IntValue") then
                                if ammoVal.Value ~= 99 then ammoVal.Value = 99 end
                            end
                            if sammoVal and sammoVal:IsA("IntValue") then
                                if sammoVal.Value ~= 9999 then sammoVal.Value = 9999 end
                            end
                        end
                    end
                end
            end
        end)
        
        task.wait(1.5)
    end
end)

local graphLines = {}
local graphPoints = 45
local speedHistory = {}
for i = 1, graphPoints do
    speedHistory[i] = 0
end

local graphBackground = Drawing.new("Square")
graphBackground.Visible = false
graphBackground.Color = Color3.fromRGB(0, 0, 0)
graphBackground.Transparency = 0.6
graphBackground.Filled = true

local graphBorder = Drawing.new("Square")
graphBorder.Visible = false
graphBorder.Color = Color3.fromRGB(255, 255, 255)
graphBorder.Transparency = 0.8
graphBorder.Filled = false
graphBorder.Thickness = 1.0

for i = 1, graphPoints - 1 do
    local line = Drawing.new("Line")
    line.Visible = false
    line.Color = Color3.fromRGB(255, 255, 255)
    line.Thickness = 1.5
    graphLines[i] = line
end

local graphLabel = Drawing.new("Text")
graphLabel.Visible = false
graphLabel.Color = Color3.fromRGB(255, 255, 255)
graphLabel.Size = 13
graphLabel.Outline = true
graphLabel.Center = true

Library:OnUnload(function()
    Library.Unloaded = true
    for _, line in ipairs(graphLines) do
        pcall(function() line:Remove() end)
    end
    pcall(function() graphBackground:Remove() end)
    pcall(function() graphBorder:Remove() end)
    pcall(function() graphLabel:Remove() end)
    
    for _, player in ipairs(Players:GetPlayers()) do
        removeDrawings(player)
    end
    
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.WalkSpeed = 16
    end
end)

local lastLookVector = Camera.CFrame.LookVector

RunService.RenderStepped:Connect(function()
    if Library.Unloaded then return end
    
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    local currentSpeed = 0
    
    if hrp and humanoid and humanoid.Health > 0 then
        local vel = hrp.Velocity
        local flatVel = Vector3.new(vel.X, 0, vel.Z)
        currentSpeed = flatVel.Magnitude
        
        if Config.Bhop then
            humanoid.WalkSpeed = Config.BhopSpeedBoost
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                if humanoid.FloorMaterial ~= Enum.Material.Air then
                    humanoid.Jump = true
                    if currentSpeed > 5 and currentSpeed < 75 then
                        local newFlat = flatVel * 1.05
                        hrp.Velocity = Vector3.new(newFlat.X, vel.Y, newFlat.Z)
                    end
                end
            end
        else
            humanoid.WalkSpeed = 16
        end
        
        if Config.AutoStrafe and humanoid.FloorMaterial == Enum.Material.Air then
            local currentLookVector = Camera.CFrame.LookVector
            local lookDelta = currentLookVector - lastLookVector
            
            if lookDelta.Magnitude > 0.0001 then
                local cameraRight = Camera.CFrame.RightVector
                local isMovingRight = lookDelta:Dot(cameraRight) > 0
                
                if currentSpeed > 2 then
                    local sideInput = 0
                    if UserInputService:IsKeyDown(Enum.KeyCode.A) or not UserInputService:GetFocusedTextBox() and isMovingRight == false then
                        sideInput = -1
                    elseif UserInputService:IsKeyDown(Enum.KeyCode.D) or not UserInputService:GetFocusedTextBox() and isMovingRight == true then
                        sideInput = 1
                    end
                    
                    if sideInput ~= 0 then
                        local rotationAngle = -sideInput * 0.04
                        local cosA = math.cos(rotationAngle)
                        local sinA = math.sin(rotationAngle)
                        
                        local rx = flatVel.X * cosA - flatVel.Z * sinA
                        local rz = flatVel.X * sinA + flatVel.Z * cosA
                        
                        local targetDirection = Vector3.new(rx, 0, rz).Unit
                        local finalVel = targetDirection * (currentSpeed + 0.22)
                        
                        hrp.Velocity = Vector3.new(finalVel.X, vel.Y, finalVel.Z)
                    end
                end
            end
        end
    end
    
    lastLookVector = Camera.CFrame.LookVector
    
    table.remove(speedHistory, 1)
    table.insert(speedHistory, currentSpeed)
    
    if Config.ShowSpeedGraph and currentSpeed > 0 then
        local viewSize = Camera.ViewportSize
        local graphWidth = 220
        local graphHeight = 55
        local startX = viewSize.X / 2 - graphWidth / 2
        local startY = viewSize.Y - 140
        
        graphBackground.Size = Vector2.new(graphWidth + 10, graphHeight + 10)
        graphBackground.Position = Vector2.new(startX - 5, startY - 5)
        graphBackground.Visible = true
        
        graphBorder.Size = Vector2.new(graphWidth + 10, graphHeight + 10)
        graphBorder.Position = Vector2.new(startX - 5, startY - 5)
        graphBorder.Visible = true
        
        local calibratedMaxSpeed = 80
        
        for i = 1, graphPoints - 1 do
            local line = graphLines[i]
            local x1 = startX + (i - 1) * (graphWidth / (graphPoints - 1))
            local y1 = startY + graphHeight - (math.min(speedHistory[i], calibratedMaxSpeed) / calibratedMaxSpeed) * graphHeight
            
            local x2 = startX + i * (graphWidth / (graphPoints - 1))
            local y2 = startY + graphHeight - (math.min(speedHistory[i + 1], calibratedMaxSpeed) / calibratedMaxSpeed) * graphHeight
            
            line.From = Vector2.new(x1, y1)
            line.To = Vector2.new(x2, y2)
            line.Visible = true
        end
        
        graphLabel.Text = string.format("SPEED: %d studs/s", math.floor(currentSpeed))
        graphLabel.Position = Vector2.new(startX + graphWidth / 2, startY + graphHeight + 18)
        graphLabel.Visible = true
    else
        graphBackground.Visible = false
        graphBorder.Visible = false
        for _, line in ipairs(graphLines) do
            line.Visible = false
        end
        graphLabel.Visible = false
    end
    
    for _, player in ipairs(Players:GetPlayers()) do
        createDrawings(player)
        local draw = cache[player]
        
        local show = false
        if Config.EspEnabled and validPlayer(player) and not isTeammate(player) then
            local pchar = player.Character
            local phrp = pchar.HumanoidRootPart
            local screenPos, onScreen = Camera:WorldToViewportPoint(phrp.Position)
            
            if onScreen then
                show = true
                
                if Config.Tracers then
                    draw.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                    draw.Tracer.To = Vector2.new(screenPos.X, screenPos.Y)
                    draw.Tracer.Color = Config.TracerColor
                    draw.Tracer.Visible = true
                else
                    draw.Tracer.Visible = false
                end
                
                if Config.NameTags then
                    local name = player.Name
                    local health = math.floor(pchar.Humanoid.Health)
                    local dist = math.floor((Camera.CFrame.Position - phrp.Position).Magnitude)
                    
                    draw.Label.Text = string.format("%s [%d HP] (%d studs)", name, health, dist)
                    draw.Label.Position = Vector2.new(screenPos.X, screenPos.Y - 30)
                    draw.Label.Color = Config.TagColor
                    draw.Label.Visible = true
                else
                    draw.Label.Visible = false
                end
            end
        end
        
        if not show then
            if draw then
                draw.Tracer.Visible = false
                draw.Label.Visible = false
            end
        end
    end
end)
